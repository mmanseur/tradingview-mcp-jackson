//@version=6
indicator("Momentum V4 [BBD-B Backtest]", overlay=true, max_labels_count=300)

// ============================================================
// Unified Momentum Indicator — auto-switches logic per ticker
//   • WPM / AEM  → Gold Momentum Pro (Donchian turtle, 13/26/55)
//   • All others → Momentum V4       (EMA cross,       8/21/50)
// Scanner reads: EMA Fast/Mid/Slow, BRK, PB, ADD, EXIT, SELL,
//                WEAK, Donchian Hi/Lo, Chandelier, ADX, Pyramid Count, IsGoldPro
// ============================================================

// ─── AUTO-DETECT GOLD TICKER ────────────────────────────────
isGoldTicker = str.contains(syminfo.ticker, "WPM") or str.contains(syminfo.ticker, "AEM")

// ─── EMA LENGTHS ────────────────────────────────────────────
f = isGoldTicker ? 13 : 8
m = isGoldTicker ? 26 : 21
s = isGoldTicker ? 55 : 50

emaFast = ta.ema(close, f)
emaMid  = ta.ema(close, m)
emaSlow = ta.ema(close, s)
atr14   = ta.atr(14)

bull_align = emaFast > emaMid and emaMid > emaSlow
bear_align = emaFast < emaMid and emaMid < emaSlow

// ─── MOMENTUM V4 SIGNALS ─────────────────────────────────────
vol_ok       = volume >= ta.sma(volume, 20) * (isGoldTicker ? 2.0 : 1.3)
above_all    = close > emaFast and close > emaMid and close > emaSlow
below_all    = close < emaFast and close < emaMid and close < emaSlow
bull_candle  = close > open and close > emaFast
bear_candle  = close < open and close < emaFast
ema_cross_up = ta.crossover(emaFast, emaMid)
ema_cross_dn = ta.crossunder(emaFast, emaMid)

var int bars_since = 99
v4_brk_raw  = bull_align and vol_ok and bull_candle and above_all and ema_cross_up
v4_sell_raw = bear_align and vol_ok and bear_candle and below_all and ema_cross_dn
v4_brk      = v4_brk_raw  and bars_since >= 3
v4_sell     = v4_sell_raw and bars_since >= 3
if v4_brk or v4_sell
    bars_since := 0
else
    bars_since += 1

v4_pb   = bull_align and low <= emaFast * 1.005 and close > emaFast and close > open and not v4_brk
v4_weak = bull_align and close < emaFast and not v4_sell

// ─── GOLD MOMENTUM PRO SIGNALS (Donchian turtle) ─────────────
adxLen      = 14
[_dp, _dm, adx] = ta.dmi(adxLen, adxLen)
adxOk       = adx > 20.0

entryHigh = ta.highest(high[1], 55)
addHigh   = ta.highest(high[1], 20)
exitLow   = ta.lowest(low[1],   20)
chandelier = ta.highest(high, 22) - atr14 * 4.5

var bool  gp_inPos = false
var int   gp_entryBar = 0
var int   gp_adds  = 0

gp_brk = close > entryHigh and bull_align and adxOk and not gp_inPos
gp_pb  = close > emaFast and low < emaFast and close > entryHigh[5] and bull_align and adxOk and not gp_brk and not gp_inPos

if (gp_brk or gp_pb) and not gp_inPos
    gp_inPos    := true
    gp_entryBar := bar_index
    gp_adds     := 0

gp_add  = gp_inPos and close > addHigh and adxOk and gp_adds < 2 and bar_index - gp_entryBar >= 10
if gp_add
    gp_adds += 1

gp_exit = gp_inPos and (close < exitLow or close < chandelier)
if gp_exit
    gp_inPos := false
    gp_adds  := 0

gp_weak = gp_inPos and close < emaFast and not gp_exit

// ─── SELECT ACTIVE SIGNALS ───────────────────────────────────
sig_brk  = isGoldTicker ? gp_brk  : v4_brk
sig_pb   = isGoldTicker ? gp_pb   : v4_pb
sig_add  = isGoldTicker ? gp_add  : false
sig_exit = isGoldTicker ? gp_exit : false
sig_sell = isGoldTicker ? false   : v4_sell
sig_weak = isGoldTicker ? gp_weak : v4_weak

// ─── PLOTS (overlay) ─────────────────────────────────────────
plot(emaFast,                      title="EMA Fast",    color=color.new(color.lime,   0), linewidth=1)
plot(emaMid,                       title="EMA Mid",     color=color.new(color.orange, 0), linewidth=1)
plot(emaSlow,                      title="EMA Slow",    color=color.new(color.red,    0), linewidth=2)
plot(isGoldTicker ? entryHigh : na, title="Donchian Hi", color=color.new(color.green, 0))
plot(isGoldTicker ? exitLow   : na, title="Donchian Lo", color=color.new(color.red,   0))
plot(isGoldTicker ? chandelier: na, title="Chandelier",  color=color.new(color.aqua,  0), style=plot.style_linebr)

// ─── DATA WINDOW OUTPUTS ─────────────────────────────────────
plot(adx,                          title="ADX",           display=display.data_window)
plot(sig_brk  ? 1 : 0,            title="BRK",           display=display.data_window)
plot(sig_pb   ? 1 : 0,            title="PB",            display=display.data_window)
plot(sig_add  ? 1 : 0,            title="ADD",           display=display.data_window)
plot(sig_exit ? 1 : 0,            title="EXIT",          display=display.data_window)
plot(sig_sell ? 1 : 0,            title="SELL",          display=display.data_window)
plot(sig_weak ? 1 : 0,            title="WEAK",          display=display.data_window)
plot(isGoldTicker ? gp_adds : 0,  title="Pyramid Count", display=display.data_window)
plot(isGoldTicker ? 1 : 0,        title="IsGoldPro",     display=display.data_window)

// ─── SIGNAL LABELS ───────────────────────────────────────────
if sig_brk
    label.new(bar_index, low, "BRK", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
if sig_pb
    label.new(bar_index, low, "PB", style=label.style_label_up, color=color.lime, textcolor=color.black, size=size.small)
if sig_add
    label.new(bar_index, high, "ADD", style=label.style_label_down, color=color.blue, textcolor=color.white, size=size.small)
if sig_exit
    label.new(bar_index, high, "EXIT", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)
if sig_sell and not isGoldTicker
    label.new(bar_index, high + atr14 * 0.5, "SELL", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)

// ─── BACKGROUND ──────────────────────────────────────────────
bgcolor(bull_align ? color.new(color.green, 92) : bear_align ? color.new(color.red, 92) : na)

// ─── ALERTS ──────────────────────────────────────────────────
alertcondition(sig_brk,  title="BRK",  message="Momentum: BREAKOUT on {{ticker}}")
alertcondition(sig_pb,   title="PB",   message="Momentum: PULLBACK on {{ticker}}")
alertcondition(sig_add,  title="ADD",  message="Gold Pro: ADD on {{ticker}}")
alertcondition(sig_exit, title="EXIT", message="Gold Pro: EXIT on {{ticker}}")
alertcondition(sig_sell, title="SELL", message="Momentum V4: SELL on {{ticker}}")
