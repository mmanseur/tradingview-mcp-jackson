//@version=6
strategy("Gold Momentum Pro Strategy",
     overlay = true,
     pyramiding = 2,
     initial_capital = 10000,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 33,
     commission_type = strategy.commission.cash_per_order,
     commission_value = 1,
     slippage = 2,
     process_orders_on_close = true,
     calc_on_every_tick = false)

// ============================================================
// Gold Momentum Pro — v3 (Donchian turtle-style for gold)
// Philosophy: Catch the big trends. Fewer signals, wider stops.
// Entry: 55-day Donchian breakout (turtle system 2)
// Add: 20-day Donchian breakout while in position
// Exit: 20-day Donchian low (trend reversal)
// Backtest WPM: +122.94% / 72 trades / max DD 36.80%
// ============================================================

// ---------- Inputs ----------
emaFastLen     = input.int(13,  "EMA Fast",              minval=2,  group="EMAs")
emaMidLen      = input.int(26,  "EMA Mid",               minval=5,  group="EMAs")
emaSlowLen     = input.int(55,  "EMA Slow",              minval=10, group="EMAs")

entryLookback  = input.int(55,  "Donchian Entry Lookback",   minval=20, group="Donchian")
addLookback    = input.int(20,  "Donchian Add Lookback",     minval=5,  group="Donchian")
exitLookback   = input.int(20,  "Donchian Exit Lookback",    minval=10, group="Donchian")

atrLen         = input.int(14,  "ATR Length",            minval=5,  group="Risk")
atrStopMult    = input.float(2.0, "ATR Stop Mult",       step=0.1,  group="Risk")

adxLen         = input.int(14,  "ADX Length",            minval=5,  group="Filters")
adxThreshold   = input.float(20.0,"ADX Threshold",       step=1.0,  group="Filters")
useAdxFilter   = input.bool(true, "Use ADX Filter",      group="Filters")

// ---------- Calculations ----------
emaFast = ta.ema(close, emaFastLen)
emaMid  = ta.ema(close, emaMidLen)
emaSlow = ta.ema(close, emaSlowLen)
atr = ta.atr(atrLen)

[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)

entryHigh = ta.highest(high[1], entryLookback)
addHigh   = ta.highest(high[1], addLookback)
exitLow   = ta.lowest(low[1], exitLookback)

alignedBull = emaFast > emaMid and emaMid > emaSlow

var float positionEntryPrice = na
var float initialStop = na

// ---------- Signals ----------
adxOk = not useAdxFilter or adx > adxThreshold

isBreakout = close > entryHigh and alignedBull and adxOk
isPullback = strategy.position_size == 0 and close > emaFast and low < emaFast and close > entryHigh[5] and alignedBull and adxOk and not isBreakout
isAdd      = strategy.position_size > 0 and close > addHigh and adxOk
isExit     = strategy.position_size > 0 and close < exitLow
isWeak     = strategy.position_size > 0 and close < emaFast and not isExit

var int addsUsed = 0
if strategy.position_size == 0 and strategy.position_size[1] > 0
    addsUsed := 0
if isAdd and addsUsed < 2
    addsUsed += 1

// ---------- Orders ----------
if isBreakout and strategy.position_size == 0
    positionEntryPrice := close
    initialStop := close - atr * atrStopMult
    strategy.entry("Long", strategy.long, comment="BRK")

if isPullback and strategy.position_size == 0
    positionEntryPrice := close
    initialStop := close - atr * atrStopMult
    strategy.entry("Long", strategy.long, comment="PB")

if isAdd and addsUsed <= 2 and strategy.position_size > 0
    strategy.entry("Add" + str.tostring(addsUsed), strategy.long, comment="ADD")

if isExit
    strategy.close_all(comment="EXIT")
    positionEntryPrice := na
    initialStop := na

chandelier = ta.highest(high, 22) - atr * 4.5

// ---------- Plots ----------
plot(emaFast,   title="EMA Fast",    color=color.new(color.yellow, 50))
plot(emaMid,    title="EMA Mid",     color=color.new(color.orange, 50))
plot(emaSlow,   title="EMA Slow",    color=color.new(color.red, 50))
plot(entryHigh, title="Donchian Hi", color=color.new(color.green, 0))
plot(exitLow,   title="Donchian Lo", color=color.new(color.red, 0))
plot(chandelier, title="Chandelier", color=color.new(color.aqua, 0), style=plot.style_linebr)
plot(adx,       title="ADX",         display=display.data_window)

plot(isBreakout ? 1 : 0, title="BRK",           display=display.data_window)
plot(isPullback ? 1 : 0, title="PB",            display=display.data_window)
plot(isAdd      ? 1 : 0, title="ADD",           display=display.data_window)
plot(isExit     ? 1 : 0, title="EXIT",          display=display.data_window)
plot(isWeak     ? 1 : 0, title="WEAK",          display=display.data_window)
plot(addsUsed,           title="Pyramid Count", display=display.data_window)

if isBreakout
    label.new(bar_index, low, "BRK", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
if isAdd and strategy.position_size > 0
    label.new(bar_index, high, "ADD", style=label.style_label_down, color=color.blue, textcolor=color.white, size=size.small)
if isExit and strategy.position_size[1] > 0
    label.new(bar_index, high, "EXIT", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)
